# Copy to .env for LOCAL DEVELOPMENT ONLY. The .env file is git-ignored and is
# NEVER bundled into the Docker image. At scoring time the harness injects the
# three FIREWORKS_/ALLOWED_MODELS vars itself.

# --- injected by the harness at evaluation time (dev values here) ---
FIREWORKS_API_KEY=fw_your_dev_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# On launch day, paste the REAL published list. Example placeholder:
ALLOWED_MODELS=accounts/fireworks/models/gemma-3-27b-it,accounts/fireworks/models/llama-v3p3-70b-instruct,accounts/fireworks/models/qwen3-4b-instruct

# --- optional local tuning (image defaults live in the Dockerfile) ---
# FORCE_REMOTE=1        # Architecture B: skip the local model entirely
# REMOTE_CATS=math,logic # always route these categories remote
# DEBUG=1               # write output/stats.json with token+routing breakdown
